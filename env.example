# ─── LLM ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── Database (local dev — Railway overrides with DATABASE_URL automatically) ─
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aggregator
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── Authenticated Source ────────────────────────────────────────────────────
AUTH_SOURCE_LOGIN_URL=https://example.com/api/auth/login
AUTH_SOURCE_DATA_URL=https://example.com/api/records
AUTH_SOURCE_USERNAME=your_username
AUTH_SOURCE_PASSWORD=your_password

# ─── Airtable ────────────────────────────────────────────────────────────────
AIRTABLE_API_KEY=your_airtable_pat_here
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# ─── Email Digest ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
DIGEST_RECIPIENT=recipient@example.com

# ─── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your_sentry_dsn_here

# ─── Pipeline Config ─────────────────────────────────────────────────────────
DRY_RUN=true        # Set to false for production
SCORE_THRESHOLD_HIGH=70
SCORE_THRESHOLD_MEDIUM=40
CRON_HOUR=7         # Run daily at 7 AM UTC
